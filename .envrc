# Set your core SDK base
export VULKAN_SDK="$HOME/VulkanSDK/1.4.341.1/macOS"

# Replace PATH_add with standard Zsh append syntax:
export PATH="$VULKAN_SDK/bin:$PATH"

# Set the rest exactly as you wrote them
export DYLD_LIBRARY_PATH="$VULKAN_SDK/lib"
export VK_DRIVER_FILES="$VULKAN_SDK/share/vulkan/icd.d/libkosmickrisp_icd.json:$VULKAN_SDK/share/vulkan/icd.d/MoltenVK_icd.json"
export VK_LAYER_PATH="$VULKAN_SDK/share/vulkan/explicit_layer.d"